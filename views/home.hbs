<!DOCTYPE html>
<html lang="en">

<head>

     {{>head}}

</head>

<body>

    <!-- PRE LOADER -->
    {{>preloader}}

    <!-- TOP NAVIGATION -->
    {{>topnav}}

    <!-- NAVIGATION BAR -->
    {{>navh}}

    <!-- HOME -->
    {{>homecarousel}}

    <!-- ABOUT -->
    <section id="about" data-stellar-background-ratio="0.5">
          <div class="container">
               <div class="row">

                    <div class="col-lg-6 col-sm-12">
                         <div class="about-info">
                              <div class="section-title wow fadeInUp" data-wow-delay="0.2s">
                                   <h4>Read our story</h4>
                                   <h2>Curry and Noodle</h2>
                              </div>

                              <div class="wow fadeInUp" data-wow-delay="0.4s">
                                   <p>Located in Winston Salem, North Carolina in the Robinhood Village Shopping Center,
                                        <strong>
                                             Curry and
                                             Noodle</strong> brings you the best in Indian, Thai and Nepalese Cuisine.
                                        Our diverse
                                        menu offering
                                        provides you an exotic selection of Thai, Indian and Nepalese dishes prepared
                                        with sumptuous
                                        tastes, accompanied by our own house blends of various sauces and spices.
                                   </p>
                                   <p>Our Chef has over 20 years of experience and takes pride in creating
                                        mouth-watering flavors
                                        by using authentic and fresh ingredients that will have you coming back for
                                        more. <strong>Curry and
                                             Noodle</strong> welcomes you to come in and enjoy the unique experience and
                                        enlighten your taste
                                        buds.</p>
                              </div>
                         </div>
                    </div>

                    <div class="col-lg-6 col-sm-12">
                         <div class="wow fadeInUp about-image" data-wow-delay="0.6s">
                              <img src="images/slider4.jpg" class="img-responsive" alt="">
                         </div>
                    </div>

               </div>
          </div>
     </section>

    <!-- Restro-Features -->
    <section class="restro-section">
          <div class="container">
               <div class="row">
                    <div class="col-lg-4">
                         <div class="tm-feature">
                              <i class="fas fa-4x fa-pepper-hot tm-feature-icon"></i>
                              <h2>Lunch Special</h2>
                              <p class="tm-feature-description">Join us everyday till 3:00 PM to enjoy our
                                   mouth-watering lunch offers comprising of Indian-Vegetarian, Non-Vegetarian and Thai
                                   Entrees</p>
                         </div>
                    </div>
                    <div class="col-lg-4">
                         <div class="tm-feature">
                              <i class="fas fa-4x fa-building tm-feature-icon"></i>
                              <h2>Our Restaurant</h2>
                              <p class="tm-feature-description">At Curry and Noodle, we aspire to provide a pleasant
                                   environment with appetizing meals and charming staffs at your service.</p>
                         </div>
                    </div>
                    <div class="col-lg-4">
                         <div class="tm-feature">
                              <i class="fas fa-4x fa-map-marked-alt tm-feature-icon"></i>
                              <h2>TakeOut</h2>
                              <p class="tm-feature-description">Bring Curry &amp; Noodle to your doorstep. We offer a
                                   variety
                                   of delivery services and takeout!</p>
                         </div>
                    </div>
               </div>
          </div>
     </section>

    <!-- ***** Reservation Us Area Starts ***** -->
    <section id="reservation">
          <div class="container">
               <div class="row">
                    <div class="col-lg-6 col-sm-12 align-self-center">
                         <div class="left-text-content">
                              <div class="section-heading">
                                   <h2>Order a delivery or Make a reservation</h2>
                              </div>
                              <div class="row">
                                   <div class="col-lg-12 col-sm-12">
                                        <div class="delivery">
                                             <img class="logo" src="images/fooddelivery.png" alt="take-away">
                                             <h4>Deliver to your doorstep!</h4>
                                             <span><a href="#">Doordash</a></span><br>
                                             <span><a href="#">Grubhub</a></span><br>
                                             <span><a href="#">Uber Eats</a></span>
                                        </div>
                                   </div>
                              </div>

                              <div class="row">
                                   <div class="col-lg-6 col-sm-12">
                                        <div class="phone">
                                             <i class="fa fa-phone"></i>
                                             <h4>Phone Numbers</h4>
                                             <span><a href="callto:336-848-4050">336-848-4050</a></span>
                                        </div>
                                   </div>
                                   <div class="col-lg-6 col-sm-12">
                                        <div class="message">
                                             <i class="fa fa-envelope"></i>
                                             <h4>Emails</h4>
                                             <span><a
                                                       href="mailto:curryandnoodlenc@gmail.com">info@noodleandcurry.com</a></span>
                                        </div>
                                   </div>
                              </div>
                         </div>
                    </div>
                    <div class="col-lg-6 col-sm-12">
                         <div class="reserve-form">
                              <form id="reserve" action="" method="post">
                                   <div class="row">
                                        <div class="col-lg-12">
                                             <h4>Table Reservation</h4>
                                        </div>
                                        <div class="col-lg-6 col-sm-12">
                                             <fieldset>
                                                  <input name="name" type="text" id="name" placeholder="Your Name*"
                                                       required="">
                                             </fieldset>
                                        </div>
                                        <div class="col-lg-6 col-sm-12">
                                             <fieldset>
                                                  <input name="email" type="text" id="email" pattern="[^ @]*@[^ @]*"
                                                       placeholder="Your Email Address" required="">
                                             </fieldset>
                                        </div>
                                        <div class="col-lg-6 col-sm-12">
                                             <fieldset>
                                                  <input name="phone" type="text" id="phone" placeholder="Phone Number*"
                                                       required="">
                                             </fieldset>
                                        </div>
                                        <div class="col-lg-6 col-sm-12">
                                             <fieldset>
                                                  <select value="number-guests" name="number-guests" id="number-guests">
                                                       <option value="number-guests">Number Of Guests</option>
                                                       <option name="1" id="1">1</option>
                                                       <option name="2" id="2">2</option>
                                                       <option name="3" id="3">3</option>
                                                       <option name="4" id="4">4</option>
                                                       <option name="5" id="5">5</option>
                                                       <option name="6" id="6">6</option>
                                                       <option name="7" id="7">7</option>
                                                       <option name="8" id="8">8</option>
                                                       <option name="9" id="9">9</option>
                                                       <option name="10" id="10">10</option>
                                                       <option name="11" id="11">11</option>
                                                       <option name="12" id="12">12</option>
                                                  </select>
                                             </fieldset>
                                        </div>
                                        <div class="col-lg-6 col-sm-12">
                                             <div class="input-group date" data-date-format="dd/mm/yyyy">
                                                  <input name="date" id="date" type="date" class="form-control"
                                                       placeholder="dd/mm/yyyy">
                                             </div>
                                        </div>
                                        <div class="col-lg-6 col-sm-12">
                                             <fieldset>
                                                  <select value="time" name="time" id="time">
                                                       <option value="time">Time</option>
                                                       <option name="Breakfast" id="Breakfast">Breakfast</option>
                                                       <option name="Lunch" id="Lunch">Lunch</option>
                                                       <option name="Dinner" id="Dinner">Dinner</option>
                                                  </select>
                                             </fieldset>
                                        </div>
                                        <div class="col-lg-12 col-sm-12">
                                             <fieldset>
                                                  <textarea name="message" rows="6" id="message" placeholder="Message"
                                                       required=""></textarea>
                                             </fieldset>
                                        </div>
                                        <div class="col-lg-12 col-sm-12">
                                             <fieldset>
                                                  <button type="submit" id="form-submit" class="main-button-icon">Make A
                                                       Reservation</button>
                                             </fieldset>
                                        </div>
                                   </div>
                              </form>
                         </div>
                    </div>
               </div>
          </div>
     </section>

    <!-- A brief detail -->
    <section id="specialities" data-stellar-background-ratio="0.5">
          <div class="container">
               <div class="row">

                    <div class="col-lg-6 col-sm-12">
                         <div class="specialities-info">
                              <div class="section-title wow fadeInUp" data-wow-delay="0.2s">
                                   <h4>Specialities</h4>
                                   <h2>Our Menu</h2>
                              </div>

                              <div class="wow fadeInLeft" data-wow-delay="0.4s">
                                   <p>Our menu has been designed to bring a taste of South Asia to Winston-Salem, NC. From
                                        naan baked
                                        daily in our tandoori oven, to curry cooked with fresh ingredients and aromatic
                                        spices, we
                                        strive to provide our customers with the best dining experience and ancient
                                        recipes. We also
                                        have a variety of vegetarian and non - vegetarian dishes to suit your dietary needs.
                                   </p>
                                   <p>
                                        Join us every day from 11:30 am to 3:00 pm for our delicious lunch special offers, which
                                        is designed to tantalize your palate.
                                        These are
                                        ancient recipes which are used by our chefs to make delectable offerings of
                                        lamb, goat,
                                        chicken, vegetables, along with kababs, freshly baked naan bread, and salads.
                                        Enjoy a
                                        delicious dessert for a perfect ending.
                                   </p>
                                   <div class="col-md-12 mt-3">
                                        <div class="form-group">
                                             <a href="menu.html">
                                                  <input type="submit" value="Explore Menu"
                                                       class="btn btn-primary section-btn py-3 px-5">
                                             </a>
                                        </div>
                                   </div>
                              </div>
                         </div>
                    </div>

                    <div class="col-lg-6 col-sm-12">
                         <div class="wow fadeInRight specialities-image" data-wow-delay="0.6s">
                              <img src="images/MainMenu.jpg" class="img-responsive" alt="">
                         </div>
                    </div>

               </div>
          </div>
     </section>

